<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.example.colorpalette.ColorPaletteView
        android:id="@+id/picker"
        android:layout_width="300dp"
        android:layout_height="300dp"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.495"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.375" />

    <SeekBar
        android:id="@+id/valueSlider"
        android:max="100"
        android:progress="100"
        app:layout_constraintTop_toBottomOf="@id/picker"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <View
        android:id="@+id/preview"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        app:layout_constraintBottom_toTopOf="@id/picker"/>

    <TextView
        android:id="@+id/info"
        android:textSize="18sp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/valueSlider"
        android:clickable="true"
        android:focusable="true"
        android:textIsSelectable="true"/>

</androidx.constraintlayout.widget.ConstraintLayout>focusable="true"
        android:textIsSelectable="true"/>

</androidx.constraintlayout.widget.ConstraintLayout>
